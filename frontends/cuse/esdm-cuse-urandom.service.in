# Systemd configuration file
#
# The ESDM /dev/urandom provider does not depend on any other system
# service except the ESDM server. Furthermore, we want to start it as early as
# possible in the boot cycle so that other services requiring
# random numbers (like SSHD, TLS-based services) benefit from it

[Unit]
Description=Entropy Source and DRNG Manager /dev/urandom
DefaultDependencies=no
After=local-fs.target
Before=shutdown.target
Conflicts=shutdown.target
StartLimitIntervalSec=500
StartLimitBurst=5
Wants=esdm-server.service
After=esdm-server.service
PartOf=esdm-linux-compat.target

[Service]
Restart=on-failure
RestartSec=5s
ExecStart=@PATH@/esdm-cuse-urandom -f --syslog
KillMode=mixed

# Filesystem
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadOnlyPaths=-/
ReadWritePaths=/dev /run

# Network
IPAddressDeny=any
PrivateNetwork=yes
RestrictAddressFamilies=AF_UNIX

# Process isolation
ProtectProc=invisible
ProcSubset=pid
ProtectControlGroups=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ProtectKernelLogs=yes
ProtectClock=yes
ProtectHostname=yes

# Privilege hardening
NoNewPrivileges=yes
RestrictSUIDSGID=yes
LimitMEMLOCK=0

# Syscall filtering
SystemCallArchitectures=native
SystemCallFilter=@system-service @mount @setuid
SystemCallFilter=~@aio @clock @cpu-emulation @debug @keyring @module @obsolete @pkey @raw-io @reboot @sandbox @swap

# Misc hardening
RestrictNamespaces=mnt cgroup net
RestrictRealtime=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
MountFlags=private
RemoveIPC=yes
UMask=0077
