# Systemd configuration file
#
# The ESDM /proc/sys/kernel/random provider does not depend on any other system
# service except the ESDM server. Furthermore, we want to start it as early as
# possible in the boot cycle so that other services requiring the proc file
# system (e.g. entropy gathering daemons) can rely on it.

[Unit]
Description=Entropy Source and DRNG Manager /proc/sys/kernel/random
DefaultDependencies=no
After=local-fs.target
Before=shutdown.target
Conflicts=shutdown.target
StartLimitIntervalSec=500
StartLimitBurst=5
Wants=esdm-server.service
After=esdm-server.service
PartOf=esdm-linux-compat.target

[Service]
Restart=on-failure
RestartSec=5s
ExecStart=@PATH@/esdm-proc --relabel --syslog -f -o allow_other /proc/sys/kernel/random
KillMode=mixed

# Filesystem
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadOnlyPaths=-/
ReadWritePaths=/proc/sys/kernel/random /run

# Network
IPAddressDeny=any
PrivateNetwork=yes
RestrictAddressFamilies=AF_UNIX

# Process isolation
ProtectProc=default
ProtectControlGroups=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectClock=yes
ProtectHostname=yes

# Privilege hardening
NoNewPrivileges=yes
RestrictSUIDSGID=yes
LimitMEMLOCK=0

# Syscall filtering
SystemCallArchitectures=native
SystemCallFilter=@system-service @mount
SystemCallFilter=~@aio @clock @cpu-emulation @debug @keyring @module @obsolete @pkey @raw-io @reboot @sandbox @setuid @swap

# Misc hardening
RestrictNamespaces=mnt cgroup net
RestrictRealtime=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
MountFlags=private
RemoveIPC=yes
UMask=0077
